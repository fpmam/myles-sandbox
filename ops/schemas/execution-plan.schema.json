{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/execution-plan.schema.json",
  "title": "Execution Plan Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "issue_id",
    "repo",
    "lane_tag",
    "contract_snapshot_hash",
    "brief_link",
    "approach_summary",
    "subsystem_ids",
    "acceptance_criteria",
    "edge_cases",
    "risk_flags",
    "migration_note",
    "rollback_note",
    "plan_deviation_note"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "lane_tag": {
      "type": "string",
      "enum": ["local-app/autonomous", "client/guarded"]
    },
    "contract_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "brief_link": {
      "type": "string",
      "minLength": 1
    },
    "approach_summary": {
      "type": "string",
      "minLength": 1
    },
    "subsystem_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/plannedCriterion"
      }
    },
    "edge_cases": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/plannedEdgeCase"
      }
    },
    "risk_flags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "none",
          "persistence_change",
          "migration",
          "destructive_action",
          "interface_contract",
          "cross_module_refactor",
          "external_integration",
          "architectural_risk",
          "recent_referee_miss_subsystem",
          "needs_replan_history"
        ]
      }
    },
    "migration_note": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "rollback_note": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "plan_deviation_note": {
      "type": ["string", "null"],
      "minLength": 1
    }
  },
  "$defs": {
    "plannedCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "planned_checks"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "planned_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "plannedEdgeCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "planned_checks"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "planned_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "risk_flags": {
            "contains": {
              "enum": ["migration", "persistence_change"]
            }
          }
        },
        "required": ["risk_flags"]
      },
      "then": {
        "properties": {
          "migration_note": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "risk_flags": {
            "contains": {
              "enum": ["migration", "persistence_change", "destructive_action"]
            }
          }
        },
        "required": ["risk_flags"]
      },
      "then": {
        "properties": {
          "rollback_note": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "risk_flags": {
            "contains": {
              "const": "none"
            }
          }
        },
        "required": ["risk_flags"]
      },
      "then": {
        "properties": {
          "risk_flags": {
            "maxItems": 1
          }
        }
      }
    }
  ]
}
